# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL="postgresql://chatbot:chatbot@localhost:5432/chatbot?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Auth
JWT_ACCESS_SECRET=change-me-to-a-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-to-a-different-random-string
JWT_REFRESH_EXPIRES_IN=7d

# Encryption (for API key storage in database)
ENCRYPTION_KEY=change-me-to-a-32-byte-secure-key

# AI Providers - DeepSeek (OpenAI-compatible API)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# AI Providers - OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# AI Providers - Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Frontend
FRONTEND_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_CHAT_PER_MIN=20
RATE_LIMIT_CHAT_PER_DAY=500
RATE_LIMIT_AUTH_PER_IP=10
RATE_LIMIT_AUTH_WINDOW_MS=300000
