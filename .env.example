# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL="postgresql://chatbot:chatbot@localhost:5432/chatbot?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Auth
JWT_ACCESS_SECRET=change-me-to-a-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-to-a-different-random-string
JWT_REFRESH_EXPIRES_IN=7d

# AI Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Frontend
FRONTEND_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_CHAT_PER_MIN=20
RATE_LIMIT_CHAT_PER_DAY=500
RATE_LIMIT_AUTH_PER_IP=10
RATE_LIMIT_AUTH_WINDOW_MS=300000
